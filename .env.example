# ============================================================
#  FICHIER D'EXEMPLE - NE PAS MODIFIER
#  Copiez ce fichier en ".env" et remplissez vos vraies valeurs
# ============================================================

# Token du bot Discord (à récupérer sur https://discord.com/developers/applications)
DISCORD_TOKEN=METS_TON_TOKEN_ICI

# IDs des salons de logs
LOGS_CHANNEL=123456789012345678
LOGS_WL_CHANNEL=123456789012345678
LOGS_TICKETS_CHANNEL=123456789012345678
LOGS_REMBOURSEMENT_CHANNEL=123456789012345678

# IDs des salons fonctionnels
VERIFICATION_CHANNEL=123456789012345678
WELCOME_CHANNEL=123456789012345678

# IDs des rôles
CITOYEN_WL_ROLE=123456789012345678
MUTED_ROLE=123456789012345678
UNVERIFIED_ROLE=123456789012345678
VERIFIED_ROLE=123456789012345678
STAFF_ROLE=123456789012345678

# Catégorie pour les tickets (0 si aucune)
TICKET_CATEGORY_ID=0

# Durée du mute automatique à 3 warns (en secondes)
AUTO_SANCTION_MUTE_DURATION=3600

# Sous-catégories optionnelles par type de ticket (0 = utilise TICKET_CATEGORY_ID)
TICKET_CHANNEL_BOUTIQUE=0
TICKET_CHANNEL_SUPERVISEUR=0
TICKET_CHANNEL_RECRUTEMENT=0
TICKET_CHANNEL_LEGAL=0
TICKET_CHANNEL_ILLEGAL=0
TICKET_CHANNEL_WIPERP=0
